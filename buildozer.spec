[app]
title = State Life App
package.name = statelifeapp
package.domain = org.statelife
source.dir = .
source.include_exts = py,png,jpg,kv,atlas
version = 0.1
requirements = python3,kivy,kivymd,pillow,secure-tarfile,qtpy,pyside6
